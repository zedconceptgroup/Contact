{
  "name": "pms-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["server", "web", "shared"],
  "scripts": {
    "install-all": "npm install --workspaces",
    "dev": "npm-run-all -p dev:server dev:web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
